# Django
DEBUG=True
SECRET_KEY=django-insecure-local-dev-fallback-key-do-not-use-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=ranktorole
POSTGRES_USER=ranktorole_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://ranktorole_user:changeme@db:5432/ranktorole

# CORS (comma-separated, required when DEBUG=False)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF Trusted Origins (comma-separated, required when DEBUG=False behind HTTPS proxy)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Claude API
ANTHROPIC_API_KEY=

# Production overrides (uncomment on EC2):
# DEBUG=False
# SECRET_KEY=<generate-with-python3 -c "import secrets; print(secrets.token_urlsafe(50))">
# ALLOWED_HOSTS=cjoewono.com,www.cjoewono.com
# CORS_ALLOWED_ORIGINS=https://cjoewono.com,https://www.cjoewono.com
# CSRF_TRUSTED_ORIGINS=https://cjoewono.com,https://www.cjoewono.com
# GOOGLE_OAUTH_REDIRECT_URI=https://cjoewono.com/auth/google/callback

# O*NET Web Services credentials (free — sign up at https://services.onetcenter.org)
ONET_USERNAME=
ONET_PASSWORD=
ONET_API_KEY=your-onet-api-key-here

# Stripe billing (Pro subscription)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/billing/cancel

# Redis cache backend                                                                                                                      
# Dev (docker compose): redis://redis:6379/0                                                                                               
# Leave blank to fall back to LocMemCache (CI, local-without-docker)                                                                       
REDIS_URL=